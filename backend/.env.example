# ─── BACKEND ENVIRONMENT VARIABLES ───

# Postgres connection string. Accepts the standard postgres:// / postgresql://
# form (as issued by most hosting panels / Coolify / Easypanel) — it's
# normalized internally to the asyncpg driver. `sslmode` is stripped since
# asyncpg doesn't understand it.
DATABASE_URL=postgres://postgres:password@<YOUR_DATABASE_SERVICE_NAME>:5432/brandedstore?sslmode=disable

# CORS — the frontend's public origin
FRONTEND_ORIGIN=http://localhost:3000

# WhatsApp Business number that order-confirmation links point to
# (international format, no "+" or spaces, e.g. 50760000000 for Panama)
WHATSAPP_NUMBER=212664365298

# Admin dashboard (login at http://localhost:8000/admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ponme-una-clave-fuerte
# Long random string used to sign session tokens. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_SECRET_KEY=cambia-esto-por-un-string-aleatorio-largo
# How long an admin session stays logged in (hours)
ADMIN_SESSION_HOURS=12

# Google Apps Script Web App URL — every order also gets appended as a row
# in a Google Sheet (see the setup steps printed by the assistant / README).
# Leave empty to disable; checkout never fails because of this.
GOOGLE_SHEETS_WEBHOOK_URL=

# CallMeBot API key — every order also gets pushed straight to your WhatsApp
# (WHATSAPP_NUMBER) with no click needed. See setup steps in
# app/services/whatsapp_notify.py. Leave empty to disable.
CALLMEBOT_API_KEY=

# ─── CONVERSIONS API (server-side ad tracking) ───
# Each platform below is independently optional — leave PIXEL_ID or
# ACCESS_TOKEN empty to disable that platform's CAPI calls (checkout never
# fails because of this). Mirrors frontend/.env.example's NEXT_PUBLIC_*_PIXEL_ID.
# See app/services/capi/ for the implementations and app/api/orders.py /
# app/api/tracking.py for where they're called.

# Meta: same Pixel ID as NEXT_PUBLIC_FB_PIXEL_ID.
FB_PIXEL_ID=
# Meta: Events Manager > Settings > Conversions API > Generate access token.
FB_CAPI_ACCESS_TOKEN=

# TikTok: same Pixel ID as NEXT_PUBLIC_TIKTOK_PIXEL_ID.
TIKTOK_PIXEL_ID=
# TikTok: Ads Manager > Assets > Events > Web Events > Manage > Generate Access Token.
TIKTOK_CAPI_ACCESS_TOKEN=

# Snapchat: same Pixel ID as NEXT_PUBLIC_SNAPCHAT_PIXEL_ID.
SNAPCHAT_PIXEL_ID=
# Snapchat: Ads Manager > Events Manager > your Pixel > Conversions API > Generate access token.
SNAPCHAT_CAPI_ACCESS_TOKEN=
