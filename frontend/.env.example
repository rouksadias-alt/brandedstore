# URL of the backend API (see ../backend). Leave empty for local dev if the
# backend runs on the default http://localhost:8000 and you're calling it via
# a relative path through a proxy — otherwise set it explicitly, e.g.
# NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# WhatsApp Business number that receives order confirmations and floating
# "chat with us" clicks, in international format with no "+" or spaces
# (e.g. 34694210495). This is the most important launch config —
# also update BUSINESS.whatsappDisplay in src/lib/products.ts to match.
NEXT_PUBLIC_WHATSAPP_NUMBER=34694210495
