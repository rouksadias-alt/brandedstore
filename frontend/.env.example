# URL of the backend API (see ../backend). Leave empty for local dev if the
# backend runs on the default http://localhost:8000 and you're calling it via
# a relative path through a proxy — otherwise set it explicitly, e.g.
# NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# WhatsApp Business number that receives order confirmations and floating
# "chat with us" clicks, in international format with no "+" or spaces
# (e.g. 50760000000 for Panama). This is the most important launch config —
# also update BUSINESS.whatsappDisplay in src/lib/products.ts to match.
NEXT_PUBLIC_WHATSAPP_NUMBER=212664365298

# Ad platform pixels for retargeting/conversion tracking — all three
# optional, leave empty to disable. Fires PageView on every page,
# InitiateCheckout on /checkout, and Purchase on /gracias after a
# successful order — each deduplicated against the backend's Conversions
# API call for the same event (see backend/.env.example's matching
# FB_PIXEL_ID / TIKTOK_PIXEL_ID / SNAPCHAT_PIXEL_ID + *_CAPI_ACCESS_TOKEN).
# Meta: Events Manager > Connect Data Sources > Web > Pixel ID.
NEXT_PUBLIC_FB_PIXEL_ID=
# TikTok: Ads Manager > Assets > Events > Web Events > Pixel ID.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
# Snapchat: Ads Manager > Assets Library > Pixels > Pixel ID.
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=
